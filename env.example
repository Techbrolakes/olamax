# Neon Postgres (pooled connection)
DATABASE_URL=

# Neon Auth — values from Neon console → Auth tab
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# TMDB (server-only)
TMDB_API_KEY=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Vercel AI Gateway — get from vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# Cron secret — shared secret Vercel Cron sends as Authorization: Bearer <secret>
CRON_SECRET=
